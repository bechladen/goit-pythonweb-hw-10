DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/contacts_db

# JWT
JWT_SECRET=change_me
JWT_ALGORITHM=HS256
JWT_EXPIRATION_SECONDS=3600

# Email (verification)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=465
MAIL_SERVER=
MAIL_FROM_NAME="Contacts API"
MAIL_STARTTLS=False
MAIL_SSL_TLS=True
MAIL_USE_CREDENTIALS=True
MAIL_VALIDATE_CERTS=True

# Cloudinary (avatars)
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS
# Comma-separated list. Use "*" to allow all.
CORS_ORIGINS=*
